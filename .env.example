# Copie para .env e preencha.
# Escolha o cérebro: "gemini" (Google) ou "openai" (compatível, mesmo stack do bot).
LLM_PROVIDER=gemini

# --- Opção A: Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Opção B: endpoint compatível com OpenAI (GitHub Models / Azure / etc.) ---
LLM_API_KEY=
LLM_BASE_URL=https://models.inference.ai.azure.com
LLM_MODEL=gpt-4o

# Porta do servidor local.
PORT=3000

# --- Segurança (v0.4) ---
# Modo: "public" (padrão, seguro p/ deploy — só o cérebro do site, painel/governança bloqueados)
#       "internal" (uso local da equipe — painel da imersão, governança e cérebro imersao liberados)
# O start-mintzie.command já usa internal. NUNCA exponha uma instância internal à internet.
MINTZIE_MODE=public

# --- Trava de senha (Basic Auth) — ESSENCIAL ao expor o painel na internet ---
# Se preenchidas, protegem TODA a instância: sem usuário+senha, ninguém entra (401).
# Use SEMPRE ao subir o painel (modo internal) numa VPS/Coolify.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Token exigido pelo /api/governance em modo public (Authorization: Bearer <token> ou ?token=).
# Sem token definido, o endpoint fica inacessível (401) — comportamento seguro por padrão.
GOVERNANCE_TOKEN=

# Origens autorizadas a chamar a API em modo public (CORS), separadas por vírgula.
ALLOWED_ORIGINS=https://netz.now,https://www.netz.now

# Rate limit por IP em modo public.
RATE_PER_MIN=8
RATE_PER_DAY=150

# Banca de testes do portal de governança (injeção temporária de prompt).
# Padrão: true no internal, false no public. Não ligue em produção.
# ALLOW_PROMPT_OVERRIDE=false
