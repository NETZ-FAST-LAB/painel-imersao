# Copie para .env e preencha.
# Escolha o cérebro: "gemini" (Google) ou "openai" (compatível, mesmo stack do bot).
LLM_PROVIDER=gemini

# --- Opção A: Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Opção B: endpoint compatível com OpenAI (GitHub Models / Azure / etc.) ---
LLM_API_KEY=
LLM_BASE_URL=https://models.inference.ai.azure.com
LLM_MODEL=gpt-4o

# Porta do servidor local.
PORT=3000
